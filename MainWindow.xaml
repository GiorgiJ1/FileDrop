<Window x:Class="FileDrop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileDrop"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="700"
         AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drag & Drop Info -->
        <Border Grid.Row="0" Height="100" Background="#e0e0e0" CornerRadius="10"
                BorderBrush="#bbb" BorderThickness="2"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                Padding="10" Margin="0,0,0,10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Drag and drop a file here (PDF, Word, Text)"
                           FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="FilePathTextBlock" Text="No file loaded"
                           Foreground="Gray" FontSize="12" HorizontalAlignment="Center" Margin="5,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Search Controls -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
            <TextBox x:Name="SearchBox" Width="300" Height="30" Margin="0,0,10,0"
                     Text="Enter search keyword..." />
            <Button x:Name="SearchButton" Content="🔍 Search" Width="100" Height="30"
                    Click="SearchButton_Click" />
        </StackPanel>

        <!-- Results -->
        <Border Grid.Row="2" BorderBrush="#ccc" BorderThickness="1" CornerRadius="5">
            <ScrollViewer>
                <ListView x:Name="ResultsList" Margin="5"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.IsDeferredScrollingEnabled="True">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Page" Width="80" DisplayMemberBinding="{Binding Page}" />
                            <GridViewColumn Header="Matched Text" Width="500" DisplayMemberBinding="{Binding Snippet}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </ScrollViewer>
        </Border>

        <!-- Status -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5,10,0,0">
            <TextBlock x:Name="StatusText" Text="Idle" FontSize="12" Foreground="DarkSlateGray" />
            <ProgressBar x:Name="LoadingBar" Width="100" Height="10" IsIndeterminate="True"
                         Visibility="Collapsed" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
